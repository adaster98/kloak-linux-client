{
  "name": "kloak-client",
  "version": "1.2.2",
  "description": "Desktop client for Kloak",
  "main": "src/main/index.js",
  "homepage": "https://kloak.app",
  "author": "Aster",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.kloak.client",
    "productName": "Kloak",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icons/icon.png",
      "category": "Network",
      "maintainer": "Aster"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico",
      "publisherName": "Aster"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "rpmbuild": "^0.0.23"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16"
  }
}
