{
  "name": "invisic-client",
  "version": "1.3.1",
  "description": "Invisic — enhanced desktop client for Kloak",
  "main": "src/main/index.js",
  "homepage": "https://kloak.app",
  "author": "Aster",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux --win"
  },
  "build": {
    "appId": "com.invisic.client",
    "productName": "Invisic",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "splash.html",
      "icons/**/*",
      "themes/**/*",
      "!addons/**/*",
      "!test-cache/**/*",
      "!**/*.map"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icons/icon.png",
      "category": "Network",
      "maintainer": "Aster"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico",
      "publisherName": "Aster"
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "rpmbuild": "^0.0.23"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
